  "help_modal.how_to_play.list": [
    "<li>• Drag shapes onto the 8×8 grid.</li>",
    "<li>• Placing cells deals damage to the enemy.</li>",
    "<li>• Completing lines/columns clears them → <b>CRIT</b>, damage, and shield.</li>",
    "<li>• <b>Reset</b> refreshes your hand but <b>ends your turn</b>.</li>",
    "<li>• Shapes <b>cannot</b> be rotated—choose your placement wisely.</li>",
    "<li>• A Boss appears <b>every 5</b> levels.</li>",
    "<li>• A <b>Shop</b> may appear after victory (costs Gold).</li>",
    "<li>• Battles may start with a <b>Modifier</b> (Hazard or Boon).</li>"
